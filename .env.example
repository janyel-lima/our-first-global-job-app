# =========================================================================
# English Volunteer - Configuração de Ambiente Local (.env)
# =========================================================================
# Copie este arquivo para um arquivo chamado exatamente ".env" na raiz do projeto.
# Todas as chaves iniciadas com "VITE_" serão expostas ao cliente (Vite).

# 2. URL de origem da aplicação (Localhost em modo desenvolvimento)
APP_URL="http://localhost:3000"

# =========================================================================
# SELETOR DE AMBIENTE FIREBASE (MODO EMULADOR VS MODO PRODUÇÃO)
# =========================================================================
#
# 👉 MODO A: EMULADOR LOCAL (Altamente recomendado para desenvolvimento local)
# Use este modo para simular completamente o Firestore e Auth offline no seu computador.
# Não requer internet para o banco de dados e evita o erro 'auth/unauthorized-domain'.
# Para rodar as emulações locais:
#   1. Certifique-se de ter o Node.js e Java instalados.
#   2. Execute: npx firebase emulators:start
#   3. Em outra aba do terminal, execute: npm run dev
#
# 👉 MODO B: PRODUÇÃO (Conexão direta com o Banco de Dados Real na Nuvem)
# Altere para "false" se deseja conectar sua versão local do VS Code aos dados reais do Firebase.
# ATENÇÃO: Para usar o login do Google neste modo a partir de 'localhost', você deve
# adicionar o domínio 'localhost' na lista de domínios autorizados do seu console Firebase:
#   Firebase Console -> Authentication -> Configurações (Settings) -> Domínios Autorizados -> Adicionar domínio: localhost
#
VITE_USE_EMULATORS=true

# 3. Configuração do Firebase para Produção (Setado via GitHub Pages Secrets no Deploy / ou .env local)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_DATABASE_ID=""
VITE_EMAILJS_SERVICE_ID=""
VITE_EMAILJS_PUBLIC_KEY=""
VITE_EMAILJS_TEMPLATE_COMM_ID=""
VITE_EMAILJS_TEMPLATE_SYS_ID=""
